{
  "crons": [
    {
      "path": "/api/cron/seo-publish",
      "schedule": "0 7 * * *"
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/news", "destination": "/api/sitemap?format=news" },
    { "source": "/api/admin/summary", "destination": "/api/admin?resource=summary" },
    { "source": "/api/admin/premium/subscriptions", "destination": "/api/admin?resource=premium/subscriptions" },
    { "source": "/api/admin/seo/landings", "destination": "/api/admin?resource=seo/landings" },
    { "source": "/api/admin/seo/generate-landings", "destination": "/api/admin?resource=seo/generate-landings" },
    { "source": "/api/address-intelligence", "destination": "/api/market-price?resource=address-intelligence" },
    { "source": "/api/property-assessment", "destination": "/api/market-price?resource=property-assessment" },
    { "source": "/api/photo-condition-analysis", "destination": "/api/market-price?resource=photo-condition-analysis" },
    { "source": "/precio-metro-cuadrado/:city", "destination": "/api/seo-page?slug=precio-metro-cuadrado/:city" },
    { "source": "/precio-metro-cuadrado/:city/", "destination": "/api/seo-page?slug=precio-metro-cuadrado/:city" },
    { "source": "/precio-alquiler/:city", "destination": "/api/seo-page?slug=precio-alquiler/:city" },
    { "source": "/precio-alquiler/:city/", "destination": "/api/seo-page?slug=precio-alquiler/:city" },
    { "source": "/saber-si-piso-esta-caro/:city", "destination": "/api/seo-page?slug=saber-si-piso-esta-caro/:city" },
    { "source": "/saber-si-piso-esta-caro/:city/", "destination": "/api/seo-page?slug=saber-si-piso-esta-caro/:city" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/premium", "destination": "/premium.html" },
    { "source": "/privacidad", "destination": "/privacidad.html" },
    { "source": "/terminos", "destination": "/terminos.html" },
    { "source": "/success", "destination": "/success.html" },
    { "source": "/cancel", "destination": "/cancel.html" }
  ]
}
